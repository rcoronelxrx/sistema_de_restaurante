// =========================

const preciosPlatos = {

  "Lomo Saltado": 25,
  "Ceviche": 30,
  "Hamburguesa": 18,
  "Pizza": 40

};

const preciosGuarnicion = {

  "Ninguna": 0,
  "Papas Fritas": 8,
  "Arroz": 5,
  "Ensalada": 7,
  "Yuca Frita": 9

};

const preciosBebida = {

  "Ninguna": 0,
  "Inca Kola": 6,
  "Coca Cola": 6,
  "Chicha Morada": 8,
  "Agua Mineral": 4

};

// =========================
// TOTAL DEL PEDIDO
// =========================

const precioPlato =
  preciosPlatos[producto];

const precioGuarnicion =
  preciosGuarnicion[guarnicion];

const precioBebida =
  preciosBebida[bebida];

const subtotal =
  precioPlato +
  precioGuarnicion +
  precioBebida;

const total =
  subtotal * cantidad;
