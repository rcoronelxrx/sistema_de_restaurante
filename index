<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Sistema de Restaurante</title>

  <!-- CSS -->
  <link rel="stylesheet" href="styles.css">
</head>

<body>

  <!-- HEADER -->
  <header>
    <h1>🍽 Parrilladas Mangomarca</h1>

    <nav>
      <ul>
        <li><a href="#">Pedidos</a></li>
        <li><a href="#">Inventario</a></li>
        <li><a href="#">Facturación</a></li>
        <li><a href="#">Reportes</a></li>
        <li><a href="#">Delivery</a></li>
      </ul>
    </nav>
  </header>

  <!-- MAIN -->
  <main>

    <!-- FORMULARIO -->
    <section class="formulario-section">

      <h2>📋 Gestión de Pedidos</h2>

      <form id="pedidoForm">

        <input 
          type="text" 
          id="cliente" 
          placeholder="Nº MESA"
          required>
        
        <select id="producto">

            <option value="">
            Seleccione un plato
            </option>

            <option value="Lomo Saltado">
                Lomo Saltado - S/ 25
            </option>

            <option value="Ceviche">
                Ceviche - S/ 30
            </option>

            <option value="Hamburguesa">
                Hamburguesa - S/ 18
            </option>

            <option value="Pizza">
                Pizza - S/ 40
            </option>
        </select>

<!-- GUARNICIONES EXTRA -->

<label for="guarnicion">
  🍟 Guarniciones Extra
</label>

        <select id="guarnicion">

            <option value="Ninguna">
            Ninguna
            </option>

            <option value="Papas Fritas">
            Papas Fritas - S/ 8
            </option>

            <option value="Arroz">
            Arroz - S/ 5
            </option>

            <option value="Ensalada">
            Ensalada - S/ 7
            </option>

            <option value="Yuca Frita">
            Yuca Frita - S/ 9
            </option>
        </select>

<!-- BEBIDAS -->

<label for="bebida">
  🥤 Bebidas
</label>

        <select id="bebida">

            <option value="Ninguna">
            Ninguna
            </option>

            <option value="Inca Kola">
            Inca Kola - S/ 6
            </option>

            <option value="Coca Cola">
            Coca Cola - S/ 6
            </option>

            <option value="Chicha Morada">
            Chicha Morada - S/ 10
            </option>

            <option value="Agua Mineral">
            Agua Mineral - S/ 4
            </option>

        </select>




        <input 
          type="number"
          id="cantidad"
          placeholder="Cantidad"
          min="1"
        >

        <textarea 
          id="comentario"
          placeholder="Observaciones del pedido">
        </textarea>

        <button type="submit">
          Enviar Pedido a Cocina
        </button>

      </form>

      <div class="inventario-alerta" id="alertaStock">
        ⚠ Stock bajo detectado en algunos productos
      </div>

      <!-- QR -->
      <div class="qr-box">

        <h3>📱 Carta QR</h3>

        <img 
          src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=CartaDigitalRestaurante"
          alt="Código QR"
        >

      </div>

    </section>

    <!-- RESULTADOS -->
    <section class="resultados-section">

      <h2>📊 Panel del Restaurante</h2>

      <article class="card">

        <h3>🧾 Facturación Electrónica</h3>

        <p>
          Emisión automática de boletas y facturas electrónicas.
        </p>
        

<!-- GALERÍA PARRILLA PERUANA -->
<section class="galeria-section">

  <h2>🔥 Parrilla Peruana</h2>

  <div class="galeria">

    <article class="imagen-card">
      <img
        src="https://images.unsplash.com/photo-1558030006-450675393462?q=80&w=1200&auto=format&fit=crop"
        alt="Parrilla peruana"
      >
      <h3>Parrilla Tradicional</h3>
    </article>

    <article class="imagen-card">
      <img
        src="https://images.unsplash.com/photo-1544025162-d76694265947?q=80&w=1200&auto=format&fit=crop"
        alt="Carnes a la parrilla"
      >
      <h3>Carnes a la Brasa</h3>
    </article>

    <article class="imagen-card">
      <img
        src="https://images.unsplash.com/photo-1528605248644-14dd04022da1?q=80&w=1200&auto=format&fit=crop"
        alt="Platos de parrilla"
      >
      <h3>Especialidad Peruana</h3>
    </article>

  </div>

</section>



      </article>

      <article class="card">

        <h3>📦 Control de Inventarios</h3>

        <p>
          Monitoreo de insumos, recetas y stock en tiempo real.
        </p>

      </article>

      <article class="card">

        <h3>🚚 Delivery</h3>

        <p>
          Gestión de pedidos a domicilio y seguimiento del repartidor.
        </p>

      </article>

      <!-- MÉTRICAS -->
      <div class="dashboard">

        <div class="metric">
          <p>Ventas del Día</p>
          <h3 id="ventas">S/ 0</h3>
        </div>

        <div class="metric">
          <p>Pedidos Realizados</p>
          <h3 id="pedidos">0</h3>
        </div>

        <div class="metric">
          <p>Ticket Promedio</p>
          <h3 id="ticket">S/ 0</h3>
        </div>

        <div class="metric">
          <p>Rendimiento/Hora</p>
          <h3 id="rendimiento">0%</h3>
        </div>

      </div>

    </section>

  </main>

  <!-- FOOTER -->
  <footer>

    <p>
      © 2026 Sistema de Restaurante | Parrilladas Mangomarca
    </p>

  </footer>

  <!-- JAVASCRIPT -->
  <script src="script.js"></script>
